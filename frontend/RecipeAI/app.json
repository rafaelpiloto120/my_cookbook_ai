{
  "expo": {
    "name": "Cook N'Eat AI",
    "slug": "mycookbook-ai",
    "version": "1.0.7",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": [
      "recipeai",
      "mycookbookai",
      "ai.mycookbook.app"
    ],
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.mycookbook.app"
    },
    "android": {
      "icon": "./assets/images/android-icon.png",
      "adaptiveIcon": {
        "backgroundColor": "#FFFDF7",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "ai.mycookbook.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "versionCode": 29
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFDF7",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-mail-composer",
      "expo-localization",
      "expo-web-browser",
      "@react-native-google-signin/google-signin",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Cook N'Eat AI to open the camera so you can log meals with a photo.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow Cook N'Eat AI to open the camera so you can log meals with a photo.",
          "photosPermission": "Allow Cook N'Eat AI to choose photos from your library so you can log meals with a photo."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#A15C38",
          "defaultChannel": "reminders"
        }
      ],
      "react-native-iap",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "871b0e81-a926-4699-ae9e-6b502d805438"
      }
    },
    "owner": "angel-solutions"
  }
}
